# Railway UI service — build-time (Vite embeds in bundle)
# Use /api — nginx proxies to ComptabiliteAPI (same-origin, no CORS needed)
VITE_API_URL=/api

# Runtime — nginx proxy target (optional override)
API_UPSTREAM=https://zaizens-account.up.railway.app

# Optional: public URL of this UI (for docs / integration settings elsewhere)
# PUBLIC_UI_URL=https://zaizens-account-ui.up.railway.app
