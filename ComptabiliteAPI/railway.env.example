# Railway API service variables
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:${PORT}
DB_CONNECTION_STRING=${{Postgres.DATABASE_URL}}
JWT_KEY=generate-a-long-random-string-min-32-chars

# Comma-separated UI origins allowed to call the API (must match your UI Railway URL)
CORS_ORIGINS=https://zaizens-account-ui.up.railway.app

# Default admin (seeded on first boot; legacy plaintext hash auto-upgraded on deploy):
#   Email: admin@comptabilite.cm
#   Password: Admin@123
Integrations__ApiKey=your-integration-key
Integrations__HmsWebhookKey=your-hms-inbound-key
Integrations__HmsBaseUrl=https://zaizens-hms.up.railway.app
Integrations__ZaizensPayrollBaseUrl=https://your-payroll.up.railway.app
