# Railway / production environment variables (reference only — set in Railway dashboard)
#
# DB_CONNECTION_STRING=${{Postgres.DATABASE_URL}}
# JWT_KEY=<32+ character secret>
# CORS_ORIGINS=https://zaizens-account-ui.up.railway.app
#
# Partner URLs (Integrations page in UI — per company, or set Integrations__* env vars):
#   Account_Core API:  https://zaizens-account.up.railway.app
#   Account_Core UI:   https://zaizens-account-ui.up.railway.app  (CORS only — not PayRoll)
#   Zaizens PayRoll:   https://zaizenspay.up.railway.app
#   HMS:               https://zaizens-hms.up.railway.app
# Integrations__ApiKey=dev-integration-key-change-in-production
# SKIP_HEAVY_DB_INIT=1
# ASPNETCORE_ENVIRONMENT=Production
